# ─────────────────────────────────────────────────────────────
# EcoScrapper 환경 변수 설정
# 복사 후 값 수정: cp .env.example .env
# .env는 .gitignore에 포함되어야 하므로 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────

# PostgreSQL 연결 설정
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ecoscrapper
DB_SSLMODE=disable

# Connection pool 설정
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_CONN_TIMEOUT=5s

# Kafka 연결 설정 (pkg/queue/config.go 기본값: localhost:9092)
# KAFKA_BROKERS=localhost:9092
